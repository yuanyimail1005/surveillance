SERVER_HOST=0.0.0.0
SERVER_PORT=5000

# Default V4L2 camera path. The app can still auto-detect a supported V4L2 node,
# and the web UI can switch between supported V4L2 and CSI sources.
CAMERA_DEVICE=/dev/video0
CAMERA_WIDTH=1920
CAMERA_HEIGHT=1080
CAMERA_FPS=25

PULSE_SINK_NAME=@DEFAULT_SINK@
PULSE_CAPTURE_SOURCE_NAME=@DEFAULT_SOURCE@
PULSE_ECHO_CANCEL_ENABLED=true
PULSE_ECHO_CANCEL_AEC_METHOD=webrtc
AUDIO_PLAYER_NICE=0
TALKBACK_PLAYBACK_GAIN=5.0

# Face recognition settings
FACE_RECOGNITION_ENABLED=true
FACE_RECOGNITION_KNOWN_FACES_DIR=./known_faces
# Leave empty for auto: detect every ~0.5s based on current FPS.
FACE_RECOGNITION_DETECT_EVERY_N_FRAMES=
FACE_RECOGNITION_MATCH_THRESHOLD=0.45
FACE_RECOGNITION_MAX_FACES=8
FACE_RECOGNITION_BACKEND=auto
FACE_RECOGNITION_YUNET_MODEL_PATH=./models/face_detection_yunet_2023mar.onnx
FACE_RECOGNITION_SFACE_MODEL_PATH=./models/face_recognition_sface_2021dec.onnx
