<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true"
    tools:context=".ui.fragments.VideoFragment">

    <!-- Video Display -->
    <ImageView
        android:id="@+id/video_display"
        android:layout_width="match_parent"
        android:layout_height="@dimen/video_player_height"
        android:contentDescription="@string/video_loading"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_dialog_info" />

    <!-- Face AI Overlay -->
    <com.example.pisurveillance.ui.views.FaceOverlayView
        android:id="@+id/face_overlay"
        android:layout_width="match_parent"
        android:layout_height="@dimen/video_player_height" />

    <!-- Loading Indicator -->
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/loading_spinner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center" />

    <!-- Control Panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="bottom"
        android:orientation="vertical"
        android:padding="@dimen/spacing_medium">

        <!-- Stream Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_medium"
            android:orientation="vertical">

            <!-- Video Status -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/video_status_icon"
                    android:layout_width="@dimen/icon_small"
                    android:layout_height="@dimen/icon_small"
                    android:contentDescription="@string/video_connected"
                    android:src="@android:drawable/ic_dialog_info" />

                <TextView
                    android:id="@+id/video_status_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_small"
                    android:text="@string/video_disconnected"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Audio Status -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/audio_status_icon"
                    android:layout_width="@dimen/icon_small"
                    android:layout_height="@dimen/icon_small"
                    android:contentDescription="@string/audio_status"
                    android:src="@android:drawable/ic_dialog_info" />

                <TextView
                    android:id="@+id/audio_status_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_small"
                    android:text="@string/audio_disabled"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Recording Status -->
        <TextView
            android:id="@+id/recording_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_small"
            android:gravity="center"
            android:text="Ready to record"
            android:textColor="@color/text_secondary"
            android:visibility="gone" />

        <!-- Talkback and Capture Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/snapshot_button"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/snapshot"
                app:icon="@android:drawable/ic_menu_camera" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/record_button"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/record"
                app:icon="@android:drawable/button_onoff_indicator_on" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/talkback_button"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_weight="1.5"
                android:text="@string/talkback_button" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
