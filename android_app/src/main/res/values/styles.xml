<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.PiSurveillance" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent</item>

        <!-- Status bar and navigation bar colors -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Background color -->
        <item name="android:windowBackground">@color/background</item>
    </style>

    <!-- Material Button Style -->
    <style name="Widget.MaterialButton.PiSurveillance" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="android:minHeight">@dimen/button_height</item>
    </style>

    <!-- Card View Style -->
    <style name="Widget.MaterialCardView.PiSurveillance" parent="Widget.MaterialComponents.CardView">
        <item name="cardElevation">@dimen/elevation_default</item>
        <item name="cardCornerRadius">@dimen/button_corner_radius</item>
    </style>
</resources>
